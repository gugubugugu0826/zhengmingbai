# ===== 基础 =====
PORT=3001
# 生产必填（R50：NODE_ENV=production 时默认值拒绝启动）
JWT_SECRET=dev-only-secret-change-me
FILE_SIGN_SECRET=dev-file-secret-change-me
DB_FILE=./data/zhengmingbai.db
UPLOAD_DIR=./uploads

# ===== Mock 开关（configs 表可热改，即时生效）=====
AI_MOCK=true
PAYMENT_CHANNEL=mock

# ===== 管理员名单（阶段2，R33）：逗号分隔手机号 =====
ADMIN_PHONES=

# ===== AI 模型（阿里云百炼 · 业务空间 key）=====
DASHSCOPE_API_KEY=
# 必须用业务空间专属域名，不要用公共域名 dashscope.aliyuncs.com
DASHSCOPE_BASE_URL=https://ws-nyo2f1ym27hvfsi8.cn-beijing.maas.aliyuncs.com/compatible-mode/v1

# ===== 存储通道（R45）：local|cos =====
STORAGE_CHANNEL=local
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=zhengmingbai-photos-1456250145
COS_REGION=ap-guangzhou

# ===== 验证码通道（R47）：mock|email|sms =====
VERIFICATION_CHANNEL=mock
# SES SendEmail API（个人账号不支持 SMTP，走 HTTPS API）；密钥复用上方 COS_SECRET_ID/KEY（CAM 需补 QcloudSESFullAccess）
# 模板 54571 审核通过 + 策略补加后，改 VERIFICATION_CHANNEL=email 重启
SES_REGION=ap-guangzhou
SES_FROM=noreply@zhengmingbai.cn
SES_TEMPLATE_ID=54571

# ===== 复查提醒（R48，QA 可调分钟级）=====
# REMIND_AFTER_MINUTES=1
# REMINDER_SCAN_INTERVAL_MS=60000

# ===== 微信小程序 =====
WECHAT_APPID=wx9f08e5badf46eaa7
WECHAT_SECRET=

