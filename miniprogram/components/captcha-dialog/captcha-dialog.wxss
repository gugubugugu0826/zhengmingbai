.mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(58, 46, 36, 0.45);
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
}

.dialog {
  width: 600rpx;
  background: #ffffff;
  border-radius: 40rpx;
  padding: 40rpx 36rpx;
  box-sizing: border-box;
}

.title {
  font-size: 34rpx;
  font-weight: 600;
  color: #5a5248;
}

.subtitle {
  margin-top: 8rpx;
  margin-bottom: 32rpx;
  font-size: 26rpx;
  color: #8a8076;
}

.row {
  display: flex;
  gap: 16rpx;
}

.code-input {
  flex: 1;
  height: 92rpx;
  background: #faf6ee;
  border: 2rpx solid #f3ede5;
  border-radius: 24rpx;
  padding: 0 28rpx;
  font-size: 30rpx;
  color: #5a5248;
  box-sizing: border-box;
}

.captcha-img-box {
  width: 220rpx;
  height: 92rpx;
  flex-shrink: 0;
  border: 2rpx solid #f3ede5;
  border-radius: 24rpx;
  overflow: hidden;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.captcha-img {
  width: 100%;
  height: 100%;
}

.captcha-placeholder {
  font-size: 22rpx;
  color: #8a8076;
}

.error {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #b66a5a;
}

.btn-row {
  display: flex;
  gap: 24rpx;
  margin-top: 32rpx;
}

.btn-cancel {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  border: 2rpx solid #f3ede5;
  border-radius: 24rpx;
  font-size: 28rpx;
  color: #8a8076;
}

.btn-ok {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  background: #b08968;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: #ffffff;
}

.btn-ok:active {
  background: #7d5a2f;
}

.btn-ok-disabled {
  opacity: 0.6;
}
