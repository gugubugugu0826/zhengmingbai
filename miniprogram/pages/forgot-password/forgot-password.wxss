.fp-card {
  margin-top: 32rpx;
  padding: 40rpx 36rpx;
}

.fp-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #5a5248;
}

.fp-subtitle {
  margin-top: 8rpx;
  margin-bottom: 32rpx;
  font-size: 26rpx;
  color: #8a8076;
}

.mb-4 {
  margin-bottom: 32rpx;
}

.code-row {
  display: flex;
  gap: 24rpx;
  margin-bottom: 16rpx;
}

.code-input {
  flex: 1;
}

.send-btn {
  width: 224rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #b08968;
  border-radius: 24rpx;
  font-size: 26rpx;
  color: #b08968;
}

.send-btn-disabled {
  border-color: #f3ede5;
  color: #8a8076;
}

.sent-hint {
  margin-bottom: 32rpx;
  font-size: 24rpx;
  color: #8a8076;
}

.mismatch {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #b66a5a;
}

.submit-btn {
  margin-top: 40rpx;
  width: 100%;
  box-sizing: border-box;
  line-height: 1.4;
}

.back-login {
  margin-top: 32rpx;
  text-align: center;
  font-size: 26rpx;
  color: #b08968;
}
