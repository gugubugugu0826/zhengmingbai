<view class="fp-page page-pad">
  <view class="card fp-card">
    <view class="fp-title">找回密码</view>
    <view class="fp-subtitle">通过注册邮箱重置密码，重置后旧密码立即失效</view>

    <view class="form-label">注册邮箱</view>
    <input
      class="input mb-4"
      type="text"
      maxlength="254"
      placeholder="you@example.com"
      value="{{email}}"
      bindinput="onEmailInput"
    />

    <view class="form-label">邮箱验证码</view>
    <view class="code-row">
      <input
        class="input code-input"
        type="number"
        maxlength="6"
        placeholder="6 位数字"
        value="{{code}}"
        bindinput="onCodeInput"
      />
      <view
        class="send-btn {{countdown > 0 ? 'send-btn-disabled' : ''}}"
        bindtap="openSendCaptcha"
      >{{countdown > 0 ? countdown + 's' : '发送验证码'}}</view>
    </view>
    <view class="sent-hint" wx:if="{{codeSent}}">
      如果这个邮箱注册过，验证码已经发过去了，记得看看垃圾邮件～
    </view>

    <view class="form-label">新密码</view>
    <input
      class="input mb-4"
      password
      maxlength="64"
      placeholder="至少 8 位，含字母和数字"
      value="{{password}}"
      bindinput="onPasswordInput"
    />

    <view class="form-label">确认新密码</view>
    <input
      class="input"
      password
      maxlength="64"
      placeholder="再输一次"
      value="{{password2}}"
      bindinput="onPassword2Input"
    />
    <view class="mismatch" wx:if="{{password2 && password !== password2}}">两次输入不一致</view>

    <button
      class="btn-primary submit-btn"
      disabled="{{submitting}}"
      bindtap="onSubmit"
    >{{submitting ? '重置中…' : '重置密码'}}</button>

    <view class="back-login" bindtap="goLogin">想起来了？回登录</view>
  </view>

  <captcha-dialog
    visible="{{captchaOpen}}"
    subtitle="通过人机验证后，重置验证码就发到你的邮箱"
    bind:close="onCaptchaClose"
    bind:verified="onCaptchaVerified"
  />
</view>
