/* 首页样式 */

.home-page {
  padding: 48rpx;
  box-sizing: border-box;
}

.header {
  position: relative;
  margin-bottom: 48rpx;
}

.greeting {
  font-size: 48rpx;
  font-weight: 700;
  color: #3A2E24;
}

.sub-greeting {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #8A7A6B;
}

.logout {
  position: absolute;
  right: 0;
  top: 12rpx;
  font-size: 24rpx;
  color: #8A7A6B;
}

.start-btn {
  width: 100%;
  height: 120rpx;
  line-height: 120rpx;
  font-size: 36rpx;
  border: none;
  margin-bottom: 64rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #3A2E24;
  margin-bottom: 24rpx;
}

.space-item {
  margin-bottom: 24rpx;
}

.space-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #3A2E24;
}

.space-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #8A7A6B;
}

.placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 64rpx 32rpx;
}

.placeholder-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.placeholder-text {
  font-size: 26rpx;
  color: #8A7A6B;
  text-align: center;
}

.placeholder-error {
  margin-top: 16rpx;
  font-size: 22rpx;
  color: #C0504D;
  text-align: center;
}
