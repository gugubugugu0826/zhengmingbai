.sec-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #5a5248;
}

.sec-sub {
  margin-top: 8rpx;
  margin-bottom: 24rpx;
  font-size: 26rpx;
  color: #8a8076;
}

.mt-6 {
  margin-top: 48rpx;
}

/* 空间类型网格（3 列） */
.space-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
}

.space-cell {
  width: 218rpx;
  padding: 28rpx 0;
  background: #ffffff;
  border: 4rpx solid transparent;
  border-radius: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(90, 82, 72, 0.06);
  text-align: center;
  box-sizing: border-box;
}

.space-cell-active {
  border-color: #b08968;
}

.space-cell-emoji {
  font-size: 44rpx;
}

.space-cell-label {
  margin-top: 8rpx;
  font-size: 28rpx;
  color: #5a5248;
}

.space-cell-active .space-cell-label {
  color: #7d5a2f;
}

.photo-head {
  display: flex;
  justify-content: flex-end;
  margin-bottom: 16rpx;
}

.pick-btns {
  display: flex;
  gap: 24rpx;
}

.pick-btn {
  flex: 1;
  font-size: 30rpx;
}

/* 缩略图横排 */
.thumb-strip {
  margin-top: 32rpx;
  white-space: nowrap;
}

.thumb-row {
  display: inline-flex;
  gap: 24rpx;
  padding: 8rpx 4rpx;
}

.thumb {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  flex-shrink: 0;
}

.thumb-img {
  width: 100%;
  height: 100%;
  border-radius: 24rpx;
  border: 2rpx solid #f3ede5;
}

.thumb-del {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #5a5248;
  color: #ffffff;
  font-size: 24rpx;
  line-height: 40rpx;
  text-align: center;
}

/* 隐私提示 */
.privacy-tip {
  margin-top: 32rpx;
  padding: 24rpx 32rpx;
  background: rgba(243, 237, 229, 0.7);
  border-radius: 40rpx;
  font-size: 24rpx;
  color: #8a8076;
  line-height: 1.7;
}

/* 保留勾选卡 */
.keep-card {
  margin-top: 48rpx;
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
}

.keep-check {
  width: 40rpx;
  height: 40rpx;
  flex-shrink: 0;
  margin-top: 4rpx;
  border: 2rpx solid #f3ede5;
  border-radius: 12rpx;
  background: #faf6ee;
  text-align: center;
  line-height: 40rpx;
  font-size: 24rpx;
  color: #ffffff;
}

.keep-check-on {
  background: #b08968;
  border-color: #b08968;
}

.keep-text {
  flex: 1;
}

.keep-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #5a5248;
}

.keep-desc {
  margin-top: 4rpx;
  font-size: 26rpx;
  color: #8a8076;
  line-height: 1.6;
}

.next-btn {
  margin-top: 64rpx;
  width: 100%;
  box-sizing: border-box;
  line-height: 1.4;
}

/* 贴士浮层 */
.tips-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(58, 46, 36, 0.45);
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tips-dialog {
  width: 600rpx;
  background: #ffffff;
  border-radius: 40rpx;
  padding: 48rpx 36rpx;
  box-sizing: border-box;
  text-align: center;
}

.tips-emoji {
  font-size: 72rpx;
}

.tips-title {
  margin-top: 16rpx;
  font-size: 34rpx;
  font-weight: 600;
  color: #5a5248;
}

.tips-desc {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #8a8076;
}

.tips-dots {
  margin-top: 32rpx;
  display: flex;
  justify-content: center;
  gap: 12rpx;
}

.tips-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 6rpx;
  background: #f3ede5;
}

.tips-dot-active {
  width: 32rpx;
  background: #b08968;
}

.tips-btns {
  margin-top: 40rpx;
  display: flex;
  gap: 24rpx;
}

.tips-skip {
  flex: 1;
  padding: 20rpx 0;
  border: 2rpx solid #f3ede5;
  border-radius: 24rpx;
  font-size: 26rpx;
  color: #8a8076;
}

.tips-next {
  flex: 1;
  padding: 20rpx 0;
  background: #b08968;
  border-radius: 24rpx;
  font-size: 26rpx;
  font-weight: 500;
  color: #ffffff;
}

.tips-next:active {
  background: #7d5a2f;
}
