.balance-card {
  border-radius: 40rpx;
  padding: 40rpx;
  background: linear-gradient(135deg, #b08968, #7d5a2f);
  color: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(125, 90, 47, 0.25);
}

.balance-label {
  font-size: 26rpx;
  opacity: 0.8;
}

.balance-num {
  margin-top: 8rpx;
  font-size: 64rpx;
  font-weight: 600;
  line-height: 1.1;
}

.balance-desc {
  margin-top: 16rpx;
  font-size: 26rpx;
  opacity: 0.9;
}

/* 用途 */
.usage-grid {
  margin-top: 32rpx;
  display: flex;
  gap: 24rpx;
}

.usage-card {
  flex: 1;
  padding: 28rpx;
}

.usage-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #5a5248;
}

.usage-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #8a8076;
  line-height: 1.5;
}

/* 获取点数 */
.get-card {
  margin-top: 32rpx;
  padding: 48rpx 32rpx;
  text-align: center;
}

.get-emoji {
  font-size: 64rpx;
}

.get-title {
  margin-top: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #5a5248;
}

.get-desc {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #8a8076;
  line-height: 1.7;
}

.get-tip {
  display: inline-block;
  margin-top: 24rpx;
  padding: 12rpx 32rpx;
  background: #f3ede5;
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #7d5a2f;
}

/* 流水 */
.group-title {
  margin: 40rpx 0 16rpx;
  padding: 0 8rpx;
  font-size: 26rpx;
  font-weight: 500;
  color: #8a8076;
}

.tx-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  margin-bottom: 16rpx;
}

.tx-info {
  flex: 1;
  min-width: 0;
}

.tx-reason {
  font-size: 28rpx;
  color: #5a5248;
}

.tx-time {
  margin-top: 4rpx;
  font-size: 24rpx;
  color: #8a8076;
}

.tx-amount {
  flex-shrink: 0;
  font-size: 32rpx;
  font-weight: 600;
}

.tx-positive {
  color: #5f855c;
}

.tx-negative {
  color: #b66a5a;
}

.load-more {
  padding: 24rpx 0;
  text-align: center;
  font-size: 26rpx;
  color: #b08968;
}
