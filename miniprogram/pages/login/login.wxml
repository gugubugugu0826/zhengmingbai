<view class="login-page">
  <!-- 品牌区 -->
  <view class="brand">
    <view class="brand-logo">🏡</view>
    <view class="brand-name">整明白</view>
    <view class="brand-slogan">拍几张照片，AI 帮你把家整明白</view>
  </view>

  <view class="card login-card">
    <view class="login-title">登录</view>
    <view class="login-subtitle">邮箱验证码或密码，任选一种回家</view>

    <!-- Tab 切换 -->
    <view class="tabs">
      <view
        class="tab-item {{tab === 'email_code' ? 'tab-active' : ''}}"
        data-tab="email_code"
        bindtap="onSwitchTab"
      >邮箱验证码</view>
      <view
        class="tab-item {{tab === 'password' ? 'tab-active' : ''}}"
        data-tab="password"
        bindtap="onSwitchTab"
      >密码登录</view>
    </view>

    <!-- 邮箱验证码 Tab -->
    <block wx:if="{{tab === 'email_code'}}">
      <view class="form-label">邮箱</view>
      <input
        class="input mb-4"
        type="text"
        maxlength="254"
        placeholder="you@example.com"
        value="{{email}}"
        bindinput="onEmailInput"
      />
      <view class="form-label">邮箱验证码</view>
      <view class="code-row">
        <input
          class="input code-input"
          type="number"
          maxlength="6"
          placeholder="6 位数字"
          value="{{emailCode}}"
          bindinput="onEmailCodeInput"
        />
        <view
          class="send-btn {{countdown > 0 ? 'send-btn-disabled' : ''}}"
          bindtap="openSendCaptcha"
        >{{countdown > 0 ? countdown + 's' : '发送验证码'}}</view>
      </view>
    </block>

    <!-- 密码登录 Tab（三行式：账号 / 密码 / 常驻图形码） -->
    <block wx:else>
      <view class="form-label">邮箱 / 手机号</view>
      <input
        class="input mb-4"
        type="text"
        maxlength="254"
        placeholder="邮箱或 11 位手机号"
        value="{{account}}"
        bindinput="onAccountInput"
      />
      <view class="form-label">密码</view>
      <input
        class="input mb-4"
        password
        maxlength="64"
        placeholder="请输入密码"
        value="{{password}}"
        bindinput="onPasswordInput"
      />
      <view class="form-label">图形验证码</view>
      <view class="code-row">
        <input
          class="input code-input"
          type="text"
          maxlength="8"
          placeholder="输入图片里的字符"
          value="{{pwdCaptchaCode}}"
          bindinput="onPwdCaptchaCodeInput"
        />
        <view class="captcha-box" bindtap="refreshPwdCaptcha">
          <image wx:if="{{pwdCaptchaSvg}}" class="captcha-img" src="{{pwdCaptchaSvg}}" mode="aspectFit" />
          <view wx:else class="captcha-placeholder">点击刷新</view>
        </view>
      </view>
    </block>

    <button
      class="btn-primary submit-btn"
      disabled="{{submitting}}"
      bindtap="onSubmit"
    >{{submitting ? '登录中…' : '登录'}}</button>

    <view class="bottom-row">
      <view class="hint">还没有账号？请先在网页端注册</view>
      <view class="forgot" bindtap="goForgotPassword">忘记密码？</view>
    </view>
  </view>

  <captcha-dialog
    visible="{{captchaOpen}}"
    subtitle="通过人机验证后，验证码就发到你的邮箱"
    bind:close="onCaptchaClose"
    bind:verified="onCaptchaVerified"
  />
</view>
