<!-- 登录页：手机号 + 验证码 Mock 登录 -->
<view class="login-page">
  <view class="logo-wrap">
    <view class="logo">整</view>
    <view class="title">整明白</view>
    <view class="subtitle">AI 整理收纳助手</view>
  </view>

  <view class="card form-card">
    <view class="field">
      <input
        class="input"
        type="number"
        maxlength="11"
        placeholder="请输入手机号"
        value="{{phone}}"
        bindinput="onPhoneInput"
      />
    </view>

    <view class="field code-field">
      <input
        class="input code-input"
        type="number"
        maxlength="4"
        placeholder="4 位验证码"
        value="{{code}}"
        bindinput="onCodeInput"
      />
      <view class="code-btn" bindtap="onGetCode">获取验证码</view>
    </view>

    <view wx:if="{{errorMsg}}" class="error-msg">{{errorMsg}}</view>

    <button
      class="btn-primary login-btn"
      disabled="{{submitting}}"
      loading="{{submitting}}"
      bindtap="onLogin"
    >
      {{submitting ? '登录中…' : '登录'}}
    </button>

    <view class="tip">开发 Mock：任意 4 位数字验证码即可登录</view>
  </view>
</view>
