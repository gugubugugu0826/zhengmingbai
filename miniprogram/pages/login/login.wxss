/* 登录页样式：暖米白底 + 橘棕主色，圆角 16px(32rpx) */

.login-page {
  min-height: 100vh;
  padding: 120rpx 48rpx 48rpx;
  box-sizing: border-box;
}

.logo-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 64rpx;
}

.logo {
  width: 128rpx;
  height: 128rpx;
  border-radius: 32rpx;
  background-color: #C08A5E;
  color: #FFFFFF;
  font-size: 56rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.title {
  margin-top: 24rpx;
  font-size: 44rpx;
  font-weight: 700;
  color: #3A2E24;
}

.subtitle {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #8A7A6B;
}

.form-card {
  padding: 48rpx 40rpx;
}

.field {
  margin-bottom: 32rpx;
}

.input {
  height: 96rpx;
  background-color: #FAF6F0;
  border-radius: 24rpx;
  padding: 0 32rpx;
  font-size: 30rpx;
  box-sizing: border-box;
}

.code-field {
  display: flex;
  align-items: center;
}

.code-input {
  flex: 1;
}

.code-btn {
  margin-left: 24rpx;
  padding: 0 24rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  color: #C08A5E;
  font-size: 26rpx;
  white-space: nowrap;
}

.error-msg {
  color: #C0504D;
  font-size: 26rpx;
  margin-bottom: 24rpx;
}

.login-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  border: none;
}

.tip {
  margin-top: 32rpx;
  text-align: center;
  font-size: 24rpx;
  color: #8A7A6B;
}
