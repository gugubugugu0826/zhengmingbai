.sec-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #5a5248;
  margin-top: 16rpx;
}

.sec-sub {
  margin-top: 8rpx;
  margin-bottom: 24rpx;
  font-size: 26rpx;
  color: #8a8076;
}

/* 步骤指示条 */
.step-bar {
  display: flex;
  gap: 12rpx;
  padding: 16rpx 0 24rpx;
}

.step-seg {
  flex: 1;
  height: 12rpx;
  border-radius: 6rpx;
  background: #f3ede5;
}

.step-seg-on {
  background: #b08968;
}

/* 偏好三件套 */
.pref-title {
  margin: 40rpx 0 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #5a5248;
}

.pref-grid {
  display: flex;
  gap: 24rpx;
}

.pref-cell {
  flex: 1;
  background: #ffffff;
  border: 4rpx solid transparent;
  border-radius: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(90, 82, 72, 0.06);
  padding: 28rpx;
  box-sizing: border-box;
}

.pref-cell-active {
  border-color: #b08968;
}

.pref-cell-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #5a5248;
}

.pref-cell-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #8a8076;
  line-height: 1.5;
}

.pref-points {
  display: inline-block;
  margin-top: 16rpx;
  background: #f3ede5;
  border-radius: 12rpx;
  padding: 4rpx 16rpx;
  font-size: 24rpx;
  color: #7d5a2f;
}

.pref-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
  background: #ffffff;
  border: 4rpx solid transparent;
  border-radius: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(90, 82, 72, 0.06);
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-sizing: border-box;
}

.pref-row-active {
  border-color: #b08968;
}

.pref-check {
  width: 40rpx;
  height: 40rpx;
  flex-shrink: 0;
  border: 2rpx solid #f3ede5;
  border-radius: 12rpx;
  background: #faf6ee;
  text-align: center;
  line-height: 40rpx;
  font-size: 24rpx;
  color: #ffffff;
}

.pref-check-on {
  background: #b08968;
  border-color: #b08968;
}

.pref-row-text {
  flex: 1;
}

.main-btn {
  margin-top: 64rpx;
  width: 100%;
  box-sizing: border-box;
  line-height: 1.4;
}

.valid-hint {
  margin-top: 16rpx;
  text-align: center;
  font-size: 24rpx;
  color: #8a8076;
}

/* 分组卡 */
.group-card {
  margin-bottom: 24rpx;
}

.group-label {
  margin-bottom: 16rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: #5a5248;
}

.group-photos {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.group-photo {
  width: 128rpx;
  height: 128rpx;
  border-radius: 24rpx;
  border: 2rpx solid #f3ede5;
}

/* 问答卡 */
.vague-empty {
  margin-top: 32rpx;
  padding: 64rpx 32rpx;
  text-align: center;
}

.vague-empty-emoji {
  font-size: 64rpx;
}

.vague-empty-title {
  margin-top: 16rpx;
  font-size: 30rpx;
  font-weight: 500;
  color: #5a5248;
}

.vague-empty-desc {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #8a8076;
}

.vague-card {
  margin-bottom: 24rpx;
}

.vague-photo {
  width: 100%;
  height: 320rpx;
  border-radius: 24rpx;
  border: 2rpx solid #f3ede5;
  margin-bottom: 16rpx;
}

.vague-q {
  font-size: 28rpx;
  font-weight: 500;
  color: #5a5248;
}

.vague-hint {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #8a8076;
}

.vague-input-row {
  margin-top: 16rpx;
  display: flex;
  gap: 16rpx;
}

.vague-input {
  flex: 1;
}

.vague-skip {
  width: 120rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #f3ede5;
  border-radius: 24rpx;
  font-size: 26rpx;
  color: #8a8076;
}

/* 忙碌遮罩 */
.busy-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(250, 246, 238, 0.9);
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
}

.busy-box {
  text-align: center;
}

.busy-spinner {
  width: 48rpx;
  height: 48rpx;
  margin: 0 auto;
  border: 4rpx solid #b08968;
  border-top-color: transparent;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

.busy-text {
  margin-top: 24rpx;
  font-size: 26rpx;
  color: #8a8076;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}
