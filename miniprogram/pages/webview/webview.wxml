<!-- webview 占位页：一期说明 + 预留 web-view 组件 -->
<web-view wx:if="{{webviewEnabled}}" src="{{webviewUrl}}"></web-view>

<view wx:else class="webview-placeholder">
  <view class="card info-card">
    <view class="info-icon">🧺</view>
    <view class="info-title">完整流程请在 H5 体验</view>
    <view class="info-desc">
      拍照识别、AI 整理建议、入柜等完整流程一期在 H5 端提供。
      小程序原生页面将于二期开发（或复用 H5 通过 web-view 承载）。
    </view>
    <view class="info-note">
      当前为骨架占位页：H5 部署到 https 域名并在小程序后台配置业务域名后，
      将本页 webviewEnabled 置为 true 即可内嵌打开。
    </view>
  </view>
</view>
