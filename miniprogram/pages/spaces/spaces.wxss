.page-sub {
  margin-top: 8rpx;
  margin-bottom: 32rpx;
  font-size: 26rpx;
  color: #8a8076;
}

.space-card {
  margin-bottom: 24rpx;
}

.space-card-focused {
  border: 4rpx solid #b08968;
}

.space-head {
  display: flex;
  align-items: center;
}

.space-emoji {
  width: 96rpx;
  height: 96rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f3ede5;
  border-radius: 24rpx;
  font-size: 48rpx;
}

.space-info {
  flex: 1;
  min-width: 0;
  margin-left: 24rpx;
}

.space-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #5a5248;
}

.space-type {
  margin-top: 4rpx;
  font-size: 24rpx;
  color: #8a8076;
}

.space-status {
  flex-shrink: 0;
  border-radius: 12rpx;
  padding: 4rpx 16rpx;
  font-size: 22rpx;
}

.status-pending {
  background: #f3ede5;
  color: #8a8076;
}

.status-doing {
  background: rgba(176, 137, 104, 0.15);
  color: #7d5a2f;
}

.status-done {
  background: rgba(123, 159, 118, 0.3);
  color: #5f855c;
}

.space-arrow {
  flex-shrink: 0;
  margin-left: 16rpx;
  color: #8a8076;
}

.space-foot {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid rgba(243, 237, 229, 0.6);
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: #8a8076;
}

.empty-emoji {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.empty-hint {
  margin-top: 8rpx;
  font-size: 24rpx;
}

.empty-btn {
  margin: 32rpx auto 0;
  width: 320rpx;
  font-size: 28rpx;
}
