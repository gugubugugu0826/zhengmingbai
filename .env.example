# ===== 基础 =====
PORT=3000
# JWT 签名密钥（生产环境务必更换）
JWT_SECRET=dev-only-secret-change-me
# 照片签名 URL 密钥
FILE_SIGN_SECRET=dev-file-secret-change-me
# SQLite 数据文件路径（相对 server 目录）
DB_FILE=./data/zhengmingbai.db
# 本地照片存储目录（一期无 COS 钥匙，用本地存储通道模拟）
UPLOAD_DIR=./uploads

# ===== Mock 开关（也可在 configs 表热改，即时生效）=====
# AI Mock：true 时 confirm/analyze/方案生成全部返回预置数据，不花一分钱
AI_MOCK=true
# 支付渠道：mock / wechat（一期只实现 mock，wechat 为二期空壳）
PAYMENT_CHANNEL=mock

# ===== 二期真实服务钥匙（一期留空即可）=====
# 通义千问视觉模型
DASHSCOPE_API_KEY=
AI_VISION_MODEL=qwen-vl-plus
AI_TEXT_MODEL=qwen-plus
# 腾讯云 COS
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=
COS_REGION=
# 微信支付（二期）
WECHAT_APPID=
WECHAT_SECRET=
WECHAT_MCH_ID=
